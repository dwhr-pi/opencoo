# opencoo — partner deployment .env (PR-X2, phase-a follow-up).
#
# Pair with: docker compose -f compose.partner.yml up -d
#
# This file is the canonical operator-facing knob set for a GHCR-pull
# deployment. The repo-root .env.example is the canonical knob set for
# a from-source contributor deployment — the two overlap deliberately
# (same env-var allow-list — THREAT-MODEL §2 invariant 9, enforced by
# the `no-feature-env-vars` ESLint rule); this file documents the
# subset operators actually need to touch and adds image-distribution-
# specific knobs (OPENCOO_TAG, OPENCOO_PORT, POSTGRES_PASSWORD).
#
# Every URL/secret env var also accepts a `_FILE` suffix variant per
# the Docker-secrets convention — see pilot-runbook.md §1 "Required
# env vars" table for the full list of `_FILE`-eligible variables.
# The compose template wires plain-string env by
# default; for production-grade secret handling, either:
#   1. Define `secrets:` blocks in compose.partner.yml and switch each
#      var to its `_FILE` form (e.g. `ENCRYPTION_KEY_FILE: /run/
#      secrets/encryption_key`), or
#   2. Front the engine with a secrets-manager-aware sidecar that
#      writes resolved values into the engine's environment before
#      `docker compose up`.

# ---------- Image distribution ----------

# Tag of the GHCR images to pull. Pin to a specific release for
# steady-state production:
#   OPENCOO_TAG=0.1.0-a.1
# `0.1.0-a` (no minor) tracks the latest phase-a rollup and is fine
# for local validation but not recommended for production.
OPENCOO_TAG=0.1.0-a

# Host port the engine binds. Defaults to 8080 to avoid colliding with
# Gitea's typical 3000.
OPENCOO_PORT=8080

# ---------- Database ----------

# Bootstrap password for the Postgres container. The compose stack
# creates the `opencoo` role with this password on first boot. Change
# it once and never again — rotating the role's password mid-flight
# without coordinating with the engine is operationally painful.
# Generate: `openssl rand -hex 24` — hex output is always URL-safe
# inside the `postgres://opencoo:PASSWORD@postgres:5432/...` userinfo
# the engine constructs. Do NOT use `openssl rand -base64 24` here:
# base64 may emit `/` or `+`, which break DSN parsing. (We do use
# base64 for ENCRYPTION_KEY because it never travels in a URL.)
POSTGRES_PASSWORD=

# ---------- Gitea (partner-owned substrate) ----------

# Base URL of the partner's existing Gitea instance. Wikis are
# committed here; the engine writes to one repo per knowledge domain.
# Example: GITEA_URL=https://gitea.partner.example
GITEA_URL=

# Service-account PAT with write scope on the wiki repos. Generate in
# Gitea → Settings → Applications → Generate New Token. Required
# scopes: `write:repository`, `write:user`, `read:organization`.
GITEA_PAT=

# Distinct from GITEA_URL: the admin-API uses GITEA_BASE_URL when
# calling Gitea's `/whoami` + `/teams` endpoints from inside the
# engine container to confirm session ownership. Usually equal to
# GITEA_URL; set explicitly if Gitea is reachable on a private
# network with a different DNS name from inside the engine container.
GITEA_BASE_URL=

# Gitea organisation that owns repos provisioned by `+ New domain` in
# the Management UI (POST /api/admin/domains). Defaults to "opencoo"
# if unset.
GITEA_PROVISION_ORG=opencoo

# ---------- Admin API + session ----------

# 32-byte base64-encoded symmetric key used by CredentialStore to
# encrypt provider secrets at rest. Generate:
#   openssl rand -base64 32
# Required. Rotating mid-flight invalidates every encrypted credential
# row — plan a maintenance window if rotating.
ENCRYPTION_KEY=

# Gitea team slug whose members are recognised as opencoo admins.
# When unset, the engine boots in static-UI-only mode (admin
# endpoints disabled).
ADMIN_TEAM_SLUG=opencoo-admins

# 32-byte base64-encoded HMAC key for admin-API session tokens +
# sovereignty-diff confirmations. Generate:
#   openssl rand -base64 32
# Required when ADMIN_TEAM_SLUG is set.
SESSION_HMAC_KEY=

# ---------- MCP wiring ----------

# Static bearer the engine uses to talk to the gitea-wiki-mcp-server.
# MUST match the value the gitea-wiki-mcp-server boots with — the
# compose stack threads the same value into both containers via env
# substitution. Generate:
#   openssl rand -hex 32
MCP_BEARER_TOKEN=

# ---------- Optional provider keys ----------

# Set when a domain's LLM policy in the management UI selects the
# corresponding provider. Each is lazily resolved by the multi-provider
# dispatcher; absent does NOT break boot — only fails the LLM call
# when that provider is actually picked.

OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ---------- Operational knobs ----------

# Logger level: 'debug' | 'info' | 'warn' | 'error'. Default: info.
LOG_LEVEL=info

# Default = "1": engine auto-applies pending Drizzle migrations under
# a pg_advisory_xact_lock BEFORE Fastify binds the listener (PR-X1).
# Set "0" to revert to the legacy manual flow:
#   docker compose run --rm opencoo opencoo migrate
OPENCOO_AUTO_MIGRATE=1
