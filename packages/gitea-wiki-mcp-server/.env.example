# ============================================================================
# gitea-wiki-mcp-server — environment configuration
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================================

# --- Transport mode -----------------------------------------------------------
# "stdio" (default) for local Claude Code usage, "http" for remote server.
MCP_MODE=stdio

# --- HTTP server settings (only used when MCP_MODE=http) ---------------------
PORT=3000
# Bind address. Use 127.0.0.1 if Caddy/proxy is on same host (recommended).
HOST=0.0.0.0

# --- Authentication -----------------------------------------------------------
# Bearer token clients send as `Authorization: Bearer <MCP_BEARER_TOKEN>`.
# Generate with: openssl rand -hex 32
MCP_BEARER_TOKEN=replace-me-with-a-long-random-string

# --- Gitea access -------------------------------------------------------------
# Personal Access Token with `read:repository` scope. Used to clone/pull repos.
GITEA_PAT=replace-me-with-gitea-pat

# Gitea base URL — used to construct clone URLs. Required.
GITEA_BASE_URL=https://gitea.example.com

# --- Repo registry ------------------------------------------------------------
# JSON array of repos to serve. One entry MUST have `default: true`.
# Fields per repo:
#   slug          — identifier used in tool `repo` param + on-disk dir name
#   owner, name   — Gitea owner + repo name (for clone URL construction)
#   default       — boolean; the one repo picked when tools omit `repo` param
#   access_tag    — optional label for future per-token scoping
REPOS=[{"slug":"my-wiki","owner":"my-org","name":"my-wiki","default":true,"access_tag":"public"}]

# --- Sync settings ------------------------------------------------------------
# Data dir where repos are cloned + indexes are written.
DATA_DIR=./data

# Interval (in minutes) for periodic `git pull`. 0 disables periodic pulls.
SYNC_INTERVAL_MIN=5

# Shared secret for Gitea webhooks (POST /refresh/:slug). HMAC-SHA256 verified.
# Generate with: openssl rand -hex 32
# Leave empty to disable webhook-driven pulls.
GITEA_WEBHOOK_SECRET=

# --- Logging ------------------------------------------------------------------
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=info

# --- Public OAuth 2.1 access (optional) --------------------------------------
# Set these ONLY when you want to expose the MCP to external OAuth 2.1 clients
# (ChatGPT Team connectors, Claude.ai remote MCP, etc.). Leave blank for
# internal-network-only deploys — the static MCP_BEARER_TOKEN keeps working.
#
# If PUBLIC_URL is set, you MUST also set GITEA_OAUTH_CLIENT_ID and
# GITEA_OAUTH_CLIENT_SECRET — it's all-or-nothing.

# Public HTTPS URL this server is reachable at. Used as the OAuth issuer and
# in the WWW-Authenticate resource_metadata hint returned on 401.
#   PUBLIC_URL=https://mcp-wiki.example.com

# Publicly-reachable Gitea URL (optional). Set this only when GITEA_BASE_URL
# points at an internal hostname that browsers can't reach (e.g. a docker
# network name). Browsers + ChatGPT use this value for authorize/token.
#   GITEA_PUBLIC_URL=https://gitea.example.com

# Gitea OAuth2 application credentials. Create the app at:
#   Gitea → Settings → Applications → OAuth2 Applications
# Add the redirect URIs your MCP clients will use, e.g. for ChatGPT:
#   https://chatgpt.com/connector_platform_oauth_redirect
#   https://chat.openai.com/connector_platform_oauth_redirect
# Then paste client_id + secret here.
#   GITEA_OAUTH_CLIENT_ID=
#   GITEA_OAUTH_CLIENT_SECRET=

# Optional Gitea admin API token. If provided, the DCR endpoint can
# auto-append previously-unseen redirect URIs to the shared OAuth app. Without
# it, the admin must add them manually via the Gitea UI.
#   GITEA_ADMIN_TOKEN=

# Comma-separated CORS origin allow-list. Empty = allow all (internal only).
# For public deploys, scope to the clients that actually need browser access.
#   CORS_ORIGINS=https://chatgpt.com,https://chat.openai.com
