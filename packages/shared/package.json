{
  "name": "@opencoo/shared",
  "version": "0.0.0",
  "private": true,
  "description": "opencoo shared kernel — DB schema, branded IDs, domain types. Single source of truth for every pgTable in the monorepo (CLAUDE.md schema-ownership rule).",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    "./db": {
      "types": "./dist/db/index.d.ts",
      "default": "./dist/db/index.js"
    },
    "./db/schema": {
      "types": "./dist/db/schema/index.d.ts",
      "default": "./dist/db/schema/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./text-normalize": {
      "types": "./dist/text-normalize.d.ts",
      "default": "./dist/text-normalize.js"
    },
    "./credential-store": {
      "types": "./dist/credential-store/index.d.ts",
      "default": "./dist/credential-store/index.js"
    },
    "./llm-router": {
      "types": "./dist/llm-router/index.d.ts",
      "default": "./dist/llm-router/index.js"
    },
    "./llm-router/testing": {
      "types": "./dist/llm-router/testing/mock-llm-client.d.ts",
      "default": "./dist/llm-router/testing/mock-llm-client.js"
    },
    "./cost-tracker": {
      "types": "./dist/cost-tracker/index.d.ts",
      "default": "./dist/cost-tracker/index.js"
    },
    "./source-adapter": {
      "types": "./dist/source-adapter/index.d.ts",
      "default": "./dist/source-adapter/index.js"
    },
    "./wiki-write": {
      "types": "./dist/wiki-write/index.d.ts",
      "default": "./dist/wiki-write/index.js"
    },
    "./wiki-write/testing": {
      "types": "./dist/wiki-write/testing/in-memory-adapter.d.ts",
      "default": "./dist/wiki-write/testing/in-memory-adapter.js"
    },
    "./adapter-contract-tests": {
      "types": "./dist/adapter-contract-tests/index.d.ts",
      "default": "./dist/adapter-contract-tests/index.js"
    },
    "./adapter-contract-tests/document-converter": {
      "types": "./dist/adapter-contract-tests/document-converter.d.ts",
      "default": "./dist/adapter-contract-tests/document-converter.js"
    },
    "./adapter-contract-tests/guard": {
      "types": "./dist/adapter-contract-tests/guard.d.ts",
      "default": "./dist/adapter-contract-tests/guard.js"
    },
    "./adapter-contract-tests/wiki-adapter": {
      "types": "./dist/adapter-contract-tests/wiki-adapter.d.ts",
      "default": "./dist/adapter-contract-tests/wiki-adapter.js"
    },
    "./webhook-verifier": {
      "types": "./dist/webhook-verifier/index.d.ts",
      "default": "./dist/webhook-verifier/index.js"
    },
    "./prompts": {
      "types": "./dist/prompts/index.d.ts",
      "default": "./dist/prompts/index.js"
    }
  },
  "files": [
    "dist/**",
    "drizzle/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "~3.0.71",
    "@ai-sdk/google": "~3.0.64",
    "@ai-sdk/openai": "~3.0.53",
    "@ai-sdk/openai-compatible": "~2.0.41",
    "ai": "~6.0.168",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@types/node": "^22.10.5",
    "drizzle-kit": "0.31.10",
    "typescript": "~5.7.2",
    "vitest": "^3.0.5"
  }
}
