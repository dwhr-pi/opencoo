{
  "name": "@opencoo/engine-self-operating",
  "version": "0.0.0",
  "private": true,
  "description": "Engine for the self-operating side of opencoo: agent runtime + Management UI hosting. Consumes the boot scaffold from @opencoo/shared/engine-scaffold so HTTP/probe/registry semantics stay in lockstep with engine-ingestion. Schema-import only — does not own any pgTable (CLAUDE.md schema-ownership rule).",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "@opencoo/shared": "workspace:*",
    "bullmq": "5.76.1",
    "cron-parser": "4.9.0",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "ioredis": "5.10.1",
    "pg": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@types/node": "^22.10.5",
    "@types/pg": "8.20.0",
    "ioredis-mock": "8.13.1",
    "typescript": "~5.7.2",
    "vitest": "^3.0.5"
  }
}
