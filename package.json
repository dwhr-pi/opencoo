{
  "name": "opencoo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "opencoo monorepo — Strategic COO OSS engine (pre-coding gate scaffolding).",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:injection": "vitest run --config vitest.injection.config.ts && pnpm --filter @opencoo/engine-ingestion test -- --run tests/classifier/injection.test.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "fixtures:regen": "pnpm --filter @opencoo/shared fixtures:regen",
    "fixtures:check": "pnpm --filter @opencoo/shared fixtures:check",
    "lint": "pnpm run lint:root",
    "lint:root": "eslint . --ignore-pattern 'tests/eslint-fixtures/**'",
    "lint:fixtures": "eslint --no-warn-ignored --no-error-on-unmatched-pattern 'tests/eslint-fixtures/**/*.{ts,tsx}'",
    "format": "prettier --write .",
    "opencoo": "node packages/cli/dist/bin.js",
    "smoke:real-data": "node --experimental-strip-types scripts/smoke-real-data.ts",
    "threat-model:preflight": "bash scripts/threat-model-preflight.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@opencoo/eslint-plugin": "workspace:*",
    "@opencoo/shared": "workspace:*",
    "@types/node": "^22.10.5",
    "@types/pg": "8.20.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@typescript-eslint/utils": "^8.21.0",
    "drizzle-orm": "0.45.2",
    "eslint": "^9.18.0",
    "eslint-plugin-import-x": "^4.6.1",
    "fastify": "5.8.5",
    "husky": "^9.1.7",
    "pg": "8.20.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.5"
  }
}
