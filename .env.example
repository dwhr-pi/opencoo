# opencoo — canonical .env allow-list
#
# THREAT-MODEL.md §2 invariant 9: only the variables listed here are read from
# the environment at runtime. Anything else — providers, integrations, domains,
# schedules, feature flags — lives in Postgres and is edited via the management
# UI (CLAUDE.md "UI-first configuration"). The `no-feature-env-vars` ESLint
# rule enforces this boundary in source.
#
# `_FILE` variants take precedence when set (Docker secrets pattern): if both
# `ENCRYPTION_KEY` and `ENCRYPTION_KEY_FILE` are set, the `_FILE` form wins.

# --- core ---
# Postgres connection string for the engine process.
DATABASE_URL=postgres://opencoo:opencoo@localhost:5432/opencoo
DATABASE_URL_FILE=

# Redis connection string for BullMQ (engine-ingestion queue/worker
# coordination). The engine sets `maxRetriesPerRequest: null` and
# `enableReadyCheck: false` per BullMQ's connection requirements.
REDIS_URL=redis://localhost:6379
REDIS_URL_FILE=

# Gitea instance URL backing the wiki repos (engine-ingestion +
# CLI provisioning consume this). Must be a valid URL.
GITEA_URL=http://localhost:3000
GITEA_URL_FILE=

# 32-byte base64-encoded symmetric key used by CredentialStore to
# encrypt provider secrets at rest. Generate with: openssl rand -base64 32
# (the loader base64-decodes; a hex string decodes to ~47 bytes and
# trips "ENCRYPTION_KEY must decode (base64) to exactly 32 bytes")
ENCRYPTION_KEY=
ENCRYPTION_KEY_FILE=

# TCP port the Fastify server binds on (engine serves API + static UI).
PORT=3000
PORT_FILE=

# One-shot token used by the CLI to mint the first admin user. Rotated after
# first boot; refusing to unset it after bootstrap is flagged by the self-op
# security agent.
ADMIN_BOOTSTRAP_TOKEN=
ADMIN_BOOTSTRAP_TOKEN_FILE=

# Absolute path to the bundled Management UI dist directory. Usually
# unset — the engine-self-operating package resolves
# packages/engine-self-operating/dist/ui/ automatically via the workspace
# turbo pipeline. Set explicitly only for custom deploy layouts where the
# engine runs outside its workspace. THREAT-MODEL §3.8.
UI_DIST_PATH=
UI_DIST_PATH_FILE=

# Gitea team slug whose members are recognised as opencoo admins by the
# admin-API session middleware (PR 28 / plan #128). Required to enable the
# Review Dashboard + Management UI; if unset, the engine boots in
# static-UI-only mode (admin endpoints disabled, surfaced via the
# `admin_api.disabled` log line). THREAT-MODEL §3.13.
ADMIN_TEAM_SLUG=opencoo-admins
ADMIN_TEAM_SLUG_FILE=

# 32-byte base64-encoded HMAC key used to sign session tokens and
# sovereignty-diff confirmations on the admin API. Generate with:
#   openssl rand -base64 32
# Required when ADMIN_TEAM_SLUG is set. THREAT-MODEL §3.13.
SESSION_HMAC_KEY=
SESSION_HMAC_KEY_FILE=

# Distinct from GITEA_URL: the admin-API uses GITEA_BASE_URL when calling
# Gitea's `/whoami` + `/teams` endpoints from inside the engine to confirm
# session ownership. In a single-host deploy the two URLs are the same;
# they diverge when Gitea is reachable on a private network only. Required
# when ADMIN_TEAM_SLUG is set.
GITEA_BASE_URL=http://localhost:3000
GITEA_BASE_URL_FILE=

# Gitea organisation that owns repos provisioned by `+ New domain` in the
# Management UI (POST /api/admin/domains). Phase-a appendix #2. Optional —
# defaults to 'opencoo' if unset. Same `_FILE` Docker-secrets convention.
GITEA_PROVISION_ORG=opencoo
GITEA_PROVISION_ORG_FILE=

# CLI-only: a Gitea PAT (scopes: read:user, read:organization) used by
# `opencoo doctor` as the fallback admin-team check when --admin-pat is
# not passed on the command line. The engine processes never read this
# variable — it's allow-listed because the CLI runs in the same env and
# uses the same _FILE Docker-secrets convention as ENCRYPTION_KEY etc.
# THREAT-MODEL §3.13.
OPENCOO_ADMIN_PAT=
OPENCOO_ADMIN_PAT_FILE=

# --- runtime ---
# Standard Node env. `production` enables strict logging + disables dev helpers.
NODE_ENV=development

# Logger level: 'debug' | 'info' | 'warn' | 'error'. Default: info.
# Unknown or empty values fall back to info. No `_FILE` variant —
# LOG_LEVEL is not a secret.
LOG_LEVEL=info

# When set to `1`, `llm-router` writes full prompts/responses to a local
# debug log for development. MUST be unset in production (leaks secrets).
LLM_DEBUG_LOG=

# Optional OpenTelemetry collector endpoint. If unset, traces are dropped.
TELEMETRY_ENDPOINT=

# Optional. Set when domain LLM policy points at provider=openrouter.
# OpenRouter speaks the OpenAI-compatible wire protocol; the multi-provider
# dispatcher in cli/serve threads this value into createProvider("openrouter")
# (PR-Q4, phase-a appendix #9). Per-provider keys (OPENAI_API_KEY /
# ANTHROPIC_API_KEY / GOOGLE_API_KEY / OLLAMA_BASE_URL / OPENROUTER_API_KEY)
# are NOT feature config — they're standard provider credentials, lazily
# read by the dispatcher only for providers actually selected in
# `domains.llm_policy`. No `_FILE` variant.
OPENROUTER_API_KEY=

# Optional. Operational opt-out for the engine-self-operating boot-time
# auto-migrate step (PR-X1, phase-a follow-up). Default = unset / "1":
# the engine acquires a pg_advisory_xact_lock and applies pending Drizzle
# migrations BEFORE Fastify binds the listener, so multiple engines starting
# concurrently never race the migrator and a fresh `git pull` does not
# require the operator to remember `opencoo migrate`. Setting "0" / "false"
# / "no" reverts to the legacy manual flow — operators using that flow
# MUST run `opencoo migrate` after every pull. No `_FILE` variant —
# this is a public boolean flag, not a credential.
OPENCOO_AUTO_MIGRATE=1
